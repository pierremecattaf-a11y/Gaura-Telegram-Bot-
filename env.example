# Copy this file to .env and fill in your values

# Telegram bot token from BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Public HTTPS URL of this server (set automatically by Railway)
BASE_URL=https://your-app.up.railway.app

# Webhook security secret — change this to anything random
WEBHOOK_SECRET=gaura-secret-change-me

# Interview mode: "group" or "dm"
INTERVIEW_MODE=group

# Storage: "memory" (testing) or "redis" (production)
STORAGE_BACKEND=memory

# Only needed if STORAGE_BACKEND=redis
# REDIS_URL=redis://default:password@host:port
